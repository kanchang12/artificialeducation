SECRET_KEY=your-secret-key-here

# Site
SITE_URL=https://aiwithai.online
PORT=8080

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Sandbox pay-as-you-go rate (INR per minute of runtime)
SANDBOX_RATE_INR_PER_MINUTE=2

# Blackbox project rate (INR per minute) - separate from sandbox
BLACKBOX_RATE_INR_PER_MINUTE=5

# Bundle deal: pay ₹500 once, get 300 minutes (vs 250 at standard rate)
BUNDLE_PRICE_INR=500
BUNDLE_MINUTES=300

# Admin dashboard
ADMIN_EMAIL=admin@aiwithai.online
ADMIN_PASSWORD=change-me


# Monthly costs are now editable from /admin (stored in Supabase settings table)
STRIPE_FEE_PERCENT=2.0
